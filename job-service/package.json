{
    "name": "xmax-test-assignment",
    "version": "1.0.0",
    "description": "XMAX 测试工程师面试编程题",
    "main": "app.js",
    "type": "module",
    "scripts": {
        "start": "node app.js",
        "dev": "node app.js",
        "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --verbose",
        "test:a": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --testPathPattern=module-a --verbose",
        "test:b": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --testPathPattern=module-b --verbose",
        "test:example": "NODE_OPTIONS='--experimental-vm-modules' jest --testPathPattern=example --verbose"
    },
    "keywords": [
        "xmax",
        "job",
        "recruitment",
        "hr",
        "test-assignment"
    ],
    "author": "XMAX Team",
    "license": "ISC",
    "dependencies": {
        "@volcengine/openapi": "^1.32.0",
        "axios": "^1.11.0",
        "dayjs": "^1.11.19",
        "dotenv": "^16.3.1",
        "express": "^5.1.0",
        "ioredis": "^5.3.2",
        "joi": "^17.11.0",
        "koa": "^2.14.2",
        "koa-bodyparser": "^4.4.1",
        "koa-cors": "^0.0.16",
        "koa-router": "^12.0.0",
        "koa-static": "^5.0.0",
        "koa-swagger-ui": "^1.1.3",
        "koa2-swagger-ui": "^5.10.0",
        "log4js": "^6.9.1",
        "mongoose": "^8.0.3",
        "swagger-jsdoc": "^6.2.8",
        "uuid": "^9.0.1"
    },
    "devDependencies": {
        "jest": "^29.7.0",
        "@jest/globals": "^29.7.0",
        "sinon": "^17.0.0",
        "cross-env": "^7.0.3",
        "supertest": "^7.0.0",
        "jsonwebtoken": "^9.0.2"
    },
    "jest": {
        "rootDir": "..",
        "testEnvironment": "node",
        "testMatch": [
            "<rootDir>/tests/**/*.test.js",
            "<rootDir>/tests/**/*.spec.js"
        ],
        "testTimeout": 30000,
        "moduleDirectories": [
            "node_modules",
            "<rootDir>/job-service/node_modules"
        ]
    }
}
